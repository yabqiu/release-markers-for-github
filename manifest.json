{
  "manifest_version": 3,
  "name": "GitHub Tags on Commits",
  "version": "0.2.0",
  "description": "Show all associated git tags next to each commit on GitHub commit list and detail pages.",
  "author": "Yanbin <yabqiu@gmail.com>",
  "homepage_url": "https://yanbin.blog",
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/commits/*",
        "https://github.com/*/*/commit/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
